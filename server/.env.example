PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/hku_student_portal
CORS_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OTP_HMAC_SECRET=change_me_otp_hmac
OTP_TTL_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_EMAIL_MINUTE_LIMIT=3
OTP_EMAIL_HOUR_LIMIT=8
OTP_IP_MINUTE_LIMIT=6
OTP_IP_HOUR_LIMIT=20
EXPOSE_DEBUG_OTP=true

ALLOWED_EMAIL_DOMAINS=hku.hk,connect.hku.hk

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=HKU Grade Portal <no-reply@hku.hk>

ADMIN_BOOTSTRAP_EMAIL=admin@hku.hk
ADMIN_BOOTSTRAP_NAME=System Admin